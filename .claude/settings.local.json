{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npx tsc --noEmit 2>&1 || true)",
      "Bash(npx ts-unused-exports tsconfig.json --ignoreFiles=next-env.d.ts 2>&1 || true)",
      "mcp__firecrawl__*",
      "mcp__playwright__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/haox/Finanskalenderen\" && npx ts-unused-exports tsconfig.json --ignoreFiles=\"next-env|next.config|src.app.layout|src.app.page|src.app.api|.next.\" 2>&1 || true"
          }
        ]
      }
    ]
  }
}
